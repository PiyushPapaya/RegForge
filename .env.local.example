# LLM providers — set at least one. The UI lets you pick which to use, and users
# can supply their own key (BYOK) via the ⚙ control even when none is set here.
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GEMINI_API_KEY=...

# Optional persistence + example gallery.
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=...
NEXT_PUBLIC_SUPABASE_ANON_KEY=...
